{
  "name": "financeiro-ficamp-backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "test": "tsx src/domain/rules.test.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name modelo-completo",
    "db:seed": "tsx prisma/seed.ts",
    "import": "tsx src/scripts/importXlsx.ts"
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.5",
    "@prisma/client": "^5.22.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.21",
    "cors": "^2.8.6",
    "express": "^4.22.2",
    "express-session": "^1.19.0",
    "typescript": "^5.9.3",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express-session": "^1.19.0",
    "prisma": "^5.22.0",
    "tsx": "^4.22.4"
  }
}
