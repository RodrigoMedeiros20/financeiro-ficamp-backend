{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16", /* Resolve o aviso de depreciação do seu editor */
    "outDir": "./dist",           /* Força a saída dos arquivos para a pasta dist */
    "rootDir": "./src",           /* Avisa que seu código fonte está dentro de src */
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}